BUFFER_MAX_CHARS=400
BUFFER_IDLE_TIMEOUT=180
MSG_MIN_LENGTH=3

RRF_K=60
RECALL_TOP_K=10
RERANK_TOP_K=3

EMBEDDING_MODEL=BAAI/bge-small-zh
EMBEDDING_DIM=512
EMBEDDING_DEVICE=cpu

ENABLE_RERANKER=false
RERANK_MODEL=BAAI/bge-reranker-base

LLM_PROVIDER=openai
LLM_MODEL=gpt-3.5-turbo
LLM_API_KEY=your-api-key-here
LLM_API_BASE=https://api.openai.com/v1

USE_MILVUS=false
MILVUS_URI=http://localhost:19530
MILVUS_COLLECTION=group_chat_memory

STORAGE_DB_PATH=./rag_memory.db

MIN_VECTOR_COUNT_FOR_IVF=200
IVF_NLIST=10

ENABLE_AUTO_FORGET=true
FORGET_DAYS=30
MAX_DOCUMENTS=10000

ENABLE_BACKUP=true
BACKUP_DIR=./backups
MAX_BACKUPS=5
